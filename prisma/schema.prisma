generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
}

enum ProductStatus {
  AVAILABLE
  ON_REQUEST
  OUT_OF_STOCK
}

enum ProductTag {
  OEM
  USED
  AFTERMARKET
  PERFORMANCE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
  SPAM
}

enum LeadScore {
  HOT
  WARM
  COLD
}

enum LeadType {
  PRODUCT_INQUIRY
  GENERAL_INQUIRY
  BULK_INQUIRY
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         Role      @default(ADMIN)
  avatar       String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  leadNotes    LeadNote[]
  blogPosts    BlogPost[]

  @@index([email])
  @@map("users")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  icon        String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@index([slug])
  @@map("categories")
}

model Product {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  description     String?
  shortDesc       String?
  sku             String?       @unique
  status          ProductStatus @default(AVAILABLE)
  tag             ProductTag    @default(OEM)
  images          String[]
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])

  // Car compatibility
  brands          String[]
  models          String[]
  years           Int[]
  variants        String[]
  fuelTypes       String[]
  countrySpecs    String[]

  // SEO
  metaTitle       String?
  metaDesc        String?

  // Stats
  viewCount       Int           @default(0)
  inquiryCount    Int           @default(0)

  isFeatured      Boolean       @default(false)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  leads           Lead[]
  reviews         Review[]

  @@index([slug])
  @@index([categoryId])
  @@index([status])
  @@index([brands])
  @@map("products")
}

model Lead {
  id              String     @id @default(cuid())
  type            LeadType   @default(PRODUCT_INQUIRY)
  status          LeadStatus @default(NEW)
  score           LeadScore  @default(COLD)

  // Contact info
  name            String
  email           String
  phone           String
  company         String?
  country         String?

  // Car details
  brand           String?
  model           String?
  year            Int?
  variant         String?
  fuelType        String?
  countrySpec     String?
  chassisNumber   String?

  // Part details
  partName        String?
  partNumber      String?
  quantity        Int?
  message         String?
  attachments     String[]

  // Relations
  productId       String?
  product         Product?   @relation(fields: [productId], references: [id])

  // Tracking
  source          String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  ipAddress       String?
  userAgent       String?

  // Timestamps
  contactedAt     DateTime?
  closedAt        DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  notes           LeadNote[]

  @@index([status])
  @@index([score])
  @@index([email])
  @@index([brand])
  @@index([createdAt])
  @@map("leads")
}

model LeadNote {
  id        String   @id @default(cuid())
  content   String
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())

  @@index([leadId])
  @@map("lead_notes")
}

model Review {
  id          String       @id @default(cuid())
  status      ReviewStatus @default(PENDING)
  rating      Int
  title       String?
  content     String
  authorName  String
  authorEmail String
  isVerified  Boolean      @default(false)
  productId   String?
  product     Product?     @relation(fields: [productId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([productId])
  @@map("reviews")
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  coverImage  String?
  tags        String[]
  category    String?
  metaTitle   String?
  metaDesc    String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  viewCount   Int       @default(0)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([isPublished])
  @@index([publishedAt])
  @@map("blog_posts")
}

model SearchLog {
  id        String   @id @default(cuid())
  query     String
  brand     String?
  model     String?
  year      Int?
  results   Int      @default(0)
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([query])
  @@index([brand])
  @@index([createdAt])
  @@map("search_logs")
}

model SiteSettings {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String
  updatedAt       DateTime @updatedAt

  @@map("site_settings")
}
